    "philosophy": {
      "eyebrow": "Philosophy",
      "title": "A calm coach, not a drill sergeant.",
      "paragraphs": [
        "We do not worship hustle. We do not celebrate grind. Strive comes from one simple belief: lasting progress grows from calm, not pressure.",
        "We celebrate momentum, the quiet strength that settles in when you honor your own rhythm. Every ritual you log traces an arc you can see over time.",
        "No guilt. No aggressive reminders. Just space to build, day by day, with intention."
      ]
    },
    "intelligence": {
      "eyebrow": "Natural intelligence",
      "title": "A conversation with your rhythm.",
      "paragraphs": [
        "Strive uses discreet intelligence to remove friction. No busywork checklists, no dense menus.",
        "You tell your day, in text or voice, and it understands, adjusts your rituals, and keeps your momentum steady."
      ],
      "messages": [
        {
          "role": "user",
          "text": "I did everything planned except the gym today."
        },
        {
          "role": "assistant",
          "text": "Got it. Reading, meditation, and journal marked as logged. Sport noted as rest for today."
        },
        {
          "role": "user",
          "text": "I want to start yoga twice a week."
        },
        {
          "role": "assistant",
          "text": "New ritual created: Yoga — Tuesday and Thursday. Your arc starts now."
        }
      ]
    },
