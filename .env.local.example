# Strive environment variables.
#
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored — never commit secrets. Variables prefixed with NEXT_PUBLIC_ are
# exposed to the browser; everything else is server-only.

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_PASSWORD=
# Postgres connection string (used by data/migrate.py and type generation).
DATABASE_URL=
# Service-role key — bypasses RLS. Server-only, never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── AI (Google Gemini, via @ai-sdk/google) ────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional model override (defaults to gemini-2.5-flash).
# STRIVE_AI_MODEL=gemini-2.5-flash

# ── Cron (pg_cron / pg_net) ───────────────────────────────────────────────────
# Shared secret the cron routes check as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=

# ── Web Push notifications (VAPID) ────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# ── Deploy / end-to-end ───────────────────────────────────────────────────────
STRIVE_PREVIEW_URL=
STRIVE_LIVE_URL=

# ── Demo account ─────────────────────────────────────────────────────
DEMO_USER_PASSWORD=
# Filled in after running scripts/seed-demo.ts.
DEMO_USER_ID=

# ── Sentry (source-map upload; capture works without it) ──────────────────────
SENTRY_AUTH_TOKEN=

# ── Linear ──────────────────────────────────────────
# Personal API key for the Strive workspace. Server-only.
LINEAR_API_KEY=
